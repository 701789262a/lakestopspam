# MODE: server | client
MODE=server

# Shared
HOST=0.0.0.0
PORT=8000

# Ingest auth (server validates client payload)
# Option A: one key for all nodes
INGEST_API_KEY=super-secret-key

# Option B: per-node keys (overrides INGEST_API_KEY when set)
# NODE_API_KEYS=node-a:key-a,node-b:key-b
NODE_API_KEYS=

# Login auth (JWT + YAML accounts)
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_IN=12h
ACCOUNTS_FILE=./config/accounts.yml

# Optional Telegram notifications (on /api/change)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Server data files
STATE_FILE=./data/state.json
LOGS_FILE=./data/events.jsonl
REVERSE_FILE=./data/reverse_requests.json
NFT_STORE_FILE=./data/nft_configs.json

# Reverse submit: validate and auto-apply nft config on server
AUTO_APPLY_NFT_ON_SUBMIT=true
NFT_APPLY_PATH=/etc/nftables.conf
NFT_BIN=nft
NFT_CMD_TIMEOUT_MS=10000

# Client mode
SERVER_URL=http://127.0.0.1:8000
NODE_NAME=node-1
API_KEY=super-secret-key
INTERVAL_MS=10000
LOG_PUSH_INTERVAL_MS=10000
REVERSE_POLL_INTERVAL_MS=10000

# nft set location
NFT_FAMILY=inet
NFT_TABLE=pve_smtp_guard
NFT_SET=banned_v4
NFT_RULESET_CMD=nft list ruleset

# JSONL packet logs read by client and forwarded to server
PACKET_LOG_FILE=./data/packet-events.jsonl
PACKET_LOG_OFFSET_FILE=./data/.packet-log.offset
