# MODE: server | client
MODE=server

# Shared
HOST=0.0.0.0
PORT=8000

# Login/JWT (server verifies clients and admins via YAML accounts)
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_IN=12h
ACCOUNTS_FILE=./config/accounts.yml

# Server data files
STATE_FILE=./data/state.json
LOGS_FILE=./data/events.jsonl
LOGS_CSV_FILE=./data/events.csv
REVERSE_FILE=./data/reverse_requests.json
NFT_STORE_FILE=./data/nft_configs.json

# Server-side ruleset validation only (no local apply on server)
VALIDATE_RULESET_ON_SERVER=true
NFT_BIN=nft
NFT_CMD_TIMEOUT_MS=10000

# Client mode
SERVER_URL=http://127.0.0.1:8000
NODE_NAME=node-1
CLIENT_USERNAME=node-1
CLIENT_PASSWORD=change-me
JWT_REFRESH_SKEW_MS=60000
INTERVAL_MS=10000
LOG_PUSH_INTERVAL_MS=10000
REVERSE_POLL_INTERVAL_MS=10000

# Packet log source on client: journal | file
PACKET_SOURCE=journal

# journalctl source (recommended)
JOURNALCTL_BIN=journalctl
JOURNAL_GREP=SMTP-GUARD
JOURNAL_CURSOR_FILE=./data/.smtp-guard.cursor
JOURNAL_BATCH_LIMIT=500
JOURNAL_TIMEOUT_MS=10000

# nft set location
NFT_FAMILY=inet
NFT_TABLE=pve_smtp_guard
NFT_SET=banned_v4
NFT_RULESET_CMD=nft list ruleset
CLIENT_NFT_APPLY_PATH=/etc/nftables.conf
CLIENT_NFT_BIN=nft
CLIENT_NFT_CMD_TIMEOUT_MS=10000

# JSONL packet logs read by client and forwarded to server (used when PACKET_SOURCE=file)
PACKET_LOG_FILE=./data/packet-events.jsonl
PACKET_LOG_OFFSET_FILE=./data/.packet-log.offset
PACKET_LOG_TRUNCATE_AFTER_SEND=true
